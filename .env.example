# Copy this file to .env and fill in your values.

# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Salon email (shown as sender on all booking emails)
SALON_EMAIL=Goodhair.daye@yahoo.com

# ── Email (SMTP) ────────────────────────────────────────────────────────
# Leave EMAIL_BACKEND as-is during development — emails print to the console.
# For production with Gmail:
#   1. Enable "App Passwords" in your Google account
#   2. Set EMAIL_BACKEND and EMAIL_HOST_PASSWORD below
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=Goodhair.daye@yahoo.com
EMAIL_HOST_PASSWORD=your-app-password-here

# ── Twilio SMS (optional) ────────────────────────────────────────────────
# Leave blank to disable SMS. To enable:
#   1. Sign up at twilio.com
#   2. Create a phone number in your Twilio console
#   3. Fill in the values below
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+12025550100
